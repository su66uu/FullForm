#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SAMPLE_GLOSSARY="${FULLFORM_SAMPLE_GLOSSARY:-$SCRIPT_DIR/fullform.json}"

find_user_home() {
    if [[ -n "${FULLFORM_INSTALL_HOME:-}" ]]; then
        printf '%s\n' "$FULLFORM_INSTALL_HOME"
        return 0
    fi

    local user="${FULLFORM_INSTALL_USER:-}"

    if [[ -z "$user" ]]; then
        user="$(stat -f "%Su" /dev/console 2>/dev/null || true)"
    fi

    if [[ -z "$user" || "$user" == "root" || "$user" == "loginwindow" ]]; then
        if [[ -n "${SUDO_USER:-}" && "${SUDO_USER:-}" != "root" ]]; then
            user="$SUDO_USER"
        else
            return 1
        fi
    fi

    dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}'
}

target_home="$(find_user_home || true)"

if [[ -z "$target_home" ]]; then
    echo "FullForm: no target user home found; skipping sample glossary install."
    exit 0
fi

target_dir="$target_home/Library/Application Support/FullForm"
target_glossary="$target_dir/fullform.json"

mkdir -p "$target_dir"

if [[ -e "$target_glossary" ]]; then
    echo "FullForm: existing glossary found at $target_glossary; leaving it unchanged."
    exit 0
fi

install -m 644 "$SAMPLE_GLOSSARY" "$target_glossary"

if [[ "$(id -u)" == "0" ]]; then
    if [[ -n "${FULLFORM_INSTALL_USER:-}" ]]; then
        chown -R "$FULLFORM_INSTALL_USER" "$target_dir" 2>/dev/null || true
    elif [[ -n "${SUDO_USER:-}" && "${SUDO_USER:-}" != "root" ]]; then
        chown -R "$SUDO_USER" "$target_dir" 2>/dev/null || true
    else
        console_user="$(stat -f "%Su" /dev/console 2>/dev/null || true)"
        if [[ -n "$console_user" && "$console_user" != "root" && "$console_user" != "loginwindow" ]]; then
            chown -R "$console_user" "$target_dir" 2>/dev/null || true
        fi
    fi
fi

echo "FullForm: installed sample glossary at $target_glossary."
